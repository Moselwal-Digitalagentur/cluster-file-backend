# PHPStan extensions enabled via phpstan/extension-installer:
#   - phpstan/phpstan-strict-rules         (from moselwal/dev)
#   - phpstan/phpstan-phpunit              (from moselwal/dev)
#   - phpstan/phpstan-deprecation-rules    (this package require-dev)
# phpstan/phpstan-deprecation-rules is pinned here directly because
# moselwal/dev currently does not require it; we want every consumer of
# deprecated 3rd-party APIs to be flagged at QA time.

includes:
    - phar://vendor/phpstan/phpstan/phpstan.phar/conf/bleedingEdge.neon

parameters:
    level: 8
    paths:
        - Classes
        - Tests
    excludePaths:
        - Tests/Functional/Bootstrap.php (?)
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true
    tmpDir: .phpstan.cache
    # The franken-php image's `php` is a caddy wrapper that doesn't accept
    # PHPStan's parallel-worker invocation (`php -c /etc/php/php.ini ...`)
    # → "Command /etc/php/php.ini is not defined". Run single-threaded
    # until the image ships a CLI-shim that proxies -c properly.
    parallel:
        maximumNumberOfProcesses: 1
